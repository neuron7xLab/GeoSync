# Copy this file to `scripts/.env` to configure the scripts CLI locally.
# Never commit secrets – keep real values on your machine or in a vault.

# Example: API tokens used by smoke tests.
# GEOSYNC_API_TOKEN=replace-me

# Secret used to sign audit records (must be at least 16 characters).
# GEOSYNC_AUDIT_SECRET=replace_with_a_16_character_minimum_secret

# Example: Override the default random seed if you need non-deterministic runs.
# SCRIPTS_RANDOM_SEED=42
