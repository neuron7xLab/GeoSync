{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geosync.dev/schemas/cns/control_ontology.schema.json",
  "title": "GeoSync CNS Control Ontology",
  "type": "object",
  "required": ["version", "axes", "variables"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "axes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Intent", "Time", "Energy", "Error", "Control"]
      },
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "axis",
          "source",
          "units",
          "owner_module",
          "contradiction_event",
          "flow"
        ],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["witness_state", "actor_state", "coherence_state", "risk_state"]
          },
          "axis": {
            "type": "string",
            "enum": ["Intent", "Time", "Energy", "Error", "Control"]
          },
          "source": { "type": "string", "minLength": 1 },
          "units": { "type": "string", "minLength": 1 },
          "owner_module": { "type": "string", "pattern": "^[a-z_][a-z0-9_]*(\\.[a-z_][a-z0-9_]*)*$" },
          "contradiction_event": {
            "type": "string",
            "pattern": "^HiddenContradiction\\.[A-Za-z][A-Za-z0-9]*$"
          },
          "flow": {
            "type": "object",
            "required": ["mode", "source_stream", "cadence_ms", "max_staleness_ms", "lag_tolerance_ms"],
            "additionalProperties": false,
            "properties": {
              "mode": { "type": "string", "enum": ["stream"] },
              "source_stream": { "type": "string", "minLength": 1 },
              "cadence_ms": { "type": "integer", "minimum": 1 },
              "max_staleness_ms": { "type": "integer", "minimum": 1 },
              "lag_tolerance_ms": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
