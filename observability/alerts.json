{
  "version": 1,
  "groups": [
    {
      "name": "geosync.execution",
      "interval": "1m",
      "rules": [
        {
          "alert": "GeoSyncOrderErrorRate",
          "expr": "sum(rate(geosync_orders_placed_total{status=\"error\"}[5m])) / sum(rate(geosync_orders_placed_total[5m])) > 0.05",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "High order error rate detected",
            "description": "More than 5% of orders failed in the last 5 minutes"
          }
        },
        {
          "alert": "GeoSyncOrderLatency",
          "expr": "histogram_quantile(0.95, sum(rate(geosync_order_placement_duration_seconds_bucket[5m])) by (le)) > 2",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Order placement latency above 2 seconds",
            "description": "P95 order placement latency exceeded the target for 10 minutes"
          }
        },
        {
          "alert": "GeoSyncOrderAckLatency",
          "expr": "geosync_order_ack_latency_quantiles_seconds{quantile=\"0.95\"} > 0.4",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Signal → ack latency breaching 400 ms",
            "description": "p95 signal to acknowledgement latency exceeded 400 ms for 5 minutes"
          }
        },
        {
          "alert": "GeoSyncSignalToFillLatency",
          "expr": "geosync_signal_to_fill_latency_quantiles_seconds{quantile=\"0.99\"} > 0.65",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Signal → fill latency breaching 650 ms",
            "description": "p99 signal to fill latency exceeded 650 ms for 5 minutes"
          }
        }
      ]
    },
    {
      "name": "geosync.risk",
      "interval": "30s",
      "rules": [
        {
          "alert": "GeoSyncKillSwitchEngaged",
          "expr": "geosync_risk_kill_switch == 1",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#1-kill-switch-triggered"
          },
          "annotations": {
            "summary": "Kill switch is ENGAGED - all trading halted",
            "description": "The global kill switch has been triggered. All order submissions are blocked. Immediate investigation required."
          }
        },
        {
          "alert": "GeoSyncCircuitBreakerOpen",
          "expr": "geosync_risk_circuit_state{state=\"open\"} == 1",
          "for": "1m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#3-risk-engine-blocking"
          },
          "annotations": {
            "summary": "Circuit breaker is OPEN",
            "description": "The risk circuit breaker has tripped and is currently open. Orders may be blocked."
          }
        },
        {
          "alert": "GeoSyncHighRejectionRate",
          "expr": "rate(geosync_risk_rejections_total[5m]) > 10",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#3-risk-engine-blocking"
          },
          "annotations": {
            "summary": "High order rejection rate by risk engine",
            "description": "More than 10 orders per minute are being rejected by the risk engine."
          }
        },
        {
          "alert": "GeoSyncCircuitBreakerTrip",
          "expr": "increase(geosync_risk_circuit_trips_total[5m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Circuit breaker has tripped",
            "description": "The risk circuit breaker has been triggered at least once in the last 5 minutes."
          }
        },
        {
          "alert": "GeoSyncHighDrawdown",
          "expr": "geosync_drawdown_percent > 5",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Portfolio drawdown exceeds 5%",
            "description": "Current portfolio drawdown has exceeded 5% for more than 10 minutes."
          }
        },
        {
          "alert": "GeoSyncCriticalDrawdown",
          "expr": "geosync_drawdown_percent > 10",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Portfolio drawdown exceeds 10% - CRITICAL",
            "description": "Current portfolio drawdown has exceeded 10%. Risk limits may trigger kill switch."
          }
        }
      ]
    },
    {
      "name": "geosync.mode",
      "interval": "1m",
      "rules": [
        {
          "alert": "GeoSyncModeTransition",
          "expr": "increase(geosync_trading_mode_transitions_total[5m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "info",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "Trading mode has changed",
            "description": "A trading mode transition occurred in the last 5 minutes. Verify this was intentional."
          }
        },
        {
          "alert": "GeoSyncLiveModeActive",
          "expr": "geosync_trading_mode{mode=\"LIVE\"} == 1",
          "for": "0m",
          "labels": {
            "severity": "info",
            "team": "trade-ops"
          },
          "annotations": {
            "summary": "System is in LIVE trading mode",
            "description": "GeoSync is currently executing real trades. Ensure proper monitoring is active."
          }
        }
      ]
    },
    {
      "name": "geosync.data",
      "interval": "2m",
      "rules": [
        {
          "alert": "GeoSyncDataIngestionFailures",
          "expr": "increase(geosync_data_ingestion_total{status=\"error\"}[10m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "data-pipeline"
          },
          "annotations": {
            "summary": "Data ingestion failure detected",
            "description": "At least one ingestion job reported errors in the last 10 minutes"
          }
        },
        {
          "alert": "GeoSyncDataFreshness",
          "expr": "max(time() - geosync_data_ingestion_duration_seconds_sum / geosync_data_ingestion_duration_seconds_count) > 300",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "data-pipeline"
          },
          "annotations": {
            "summary": "Data ingestion freshness degraded",
            "description": "Average ingestion lag exceeded five minutes"
          }
        }
      ]
    },
    {
      "name": "geosync.strategy",
      "interval": "1m",
      "rules": [
        {
          "alert": "GeoSyncBacktestFailures",
          "expr": "increase(geosync_backtest_total{status=\"error\"}[30m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "research"
          },
          "annotations": {
            "summary": "Backtest run failed",
            "description": "At least one strategy backtest ended with an error in the last 30 minutes"
          }
        },
        {
          "alert": "GeoSyncOptimizationSlow",
          "expr": "avg(rate(geosync_optimization_duration_seconds_sum[30m]) / rate(geosync_optimization_duration_seconds_count[30m])) > 120",
          "for": "30m",
          "labels": {
            "severity": "info",
            "team": "research"
          },
          "annotations": {
            "summary": "Strategy optimisation running slowly",
            "description": "Average optimisation duration exceeded two minutes"
          }
        }
      ]
    },
    {
      "name": "geosync.model",
      "interval": "1m",
      "rules": [
        {
          "alert": "GeoSyncModelLatencyHigh",
          "expr": "geosync_model_inference_latency_quantiles_seconds{quantile=\"p99\"} > 0.5",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#4-ml-errors-timeouts"
          },
          "annotations": {
            "summary": "ML model inference latency is high",
            "description": "p99 model inference latency exceeded 500ms for 5 minutes"
          }
        },
        {
          "alert": "GeoSyncModelErrorRateHigh",
          "expr": "geosync_model_inference_error_ratio > 0.01",
          "for": "5m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#4-ml-errors-timeouts"
          },
          "annotations": {
            "summary": "ML model error rate exceeds 1%",
            "description": "Model inference error ratio has exceeded 1% for 5 minutes"
          }
        },
        {
          "alert": "GeoSyncModelDegradation",
          "expr": "increase(geosync_model_quality_degradation_events_total[15m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "ml-ops"
          },
          "annotations": {
            "summary": "Model quality degradation detected",
            "description": "At least one model quality degradation event was emitted in the last 15 minutes"
          }
        }
      ]
    },
    {
      "name": "geosync.operations",
      "interval": "1m",
      "rules": [
        {
          "alert": "GeoSyncCriticalIncidentOpen",
          "expr": "geosync_incidents_open{severity=\"critical\"} > 0",
          "for": "0m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Critical incident requires response",
            "description": "At least one critical incident is open and unmitigated"
          }
        },
        {
          "alert": "GeoSyncIncidentAckSLA",
          "expr": "histogram_quantile(0.5, sum(rate(geosync_incident_ack_latency_seconds_bucket[5m])) by (le, severity)) > 300",
          "for": "10m",
          "labels": {
            "severity": "warning",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Median incident acknowledgement breached 5 minutes",
            "description": "Incident acknowledgement time exceeded the 5 minute SLA"
          }
        },
        {
          "alert": "GeoSyncLifecycleCheckpointBlocked",
          "expr": "max by (checkpoint) (geosync_lifecycle_checkpoint_status{status=\"blocked\"}) == 1",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Lifecycle checkpoint blocked",
            "description": "A lifecycle checkpoint is blocked for more than five minutes"
          }
        },
        {
          "alert": "GeoSyncRunbookFailures",
          "expr": "increase(geosync_runbook_executions_total{outcome=\"failed\"}[15m]) > 0",
          "for": "0m",
          "labels": {
            "severity": "warning",
            "team": "platform-ops"
          },
          "annotations": {
            "summary": "Runbook execution failed",
            "description": "At least one production runbook failed in the last 15 minutes"
          }
        },
        {
          "alert": "GeoSyncMetricsMissing",
          "expr": "absent(up{job=\"geosync\"})",
          "for": "5m",
          "labels": {
            "severity": "critical",
            "team": "platform-ops",
            "runbook": "docs/INCIDENT_RUNBOOK.md#5-metrics-logs-missing"
          },
          "annotations": {
            "summary": "GeoSync metrics are missing",
            "description": "Prometheus cannot scrape metrics from GeoSync. Service may be down or unreachable."
          }
        }
      ]
    }
  ]
}
