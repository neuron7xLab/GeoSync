%% GeoSync system overview context diagram (2025 revision)
flowchart LR
    subgraph External[External & Internal Sources]
        Mkt[Market Data APIs]
        Alt[Alternative Data Providers]
        News[News & Sentiment Feeds]
        Ops[Brokerage & Order Events]
        ERP[Internal Risk & ERP Systems]
    end

    subgraph Integration[Ingestion & Streaming Fabric]
        Sched[Event Scheduler]
        Connect[Connector Workers]
        Stream[Streaming ETL]
        Quality[Data Quality Gates]
        Bus[Event Bus]
    end

    subgraph Core[Core Platform]
        subgraph DataLayer[Data & Feature Platform]
            Lake[Analytical Data Lake]
            Warehouse[Operational Warehouse]
            Catalog[Metadata Catalog]
            FS[Feature Store]
        end
        subgraph ModelOps[Model Ops & Governance]
            Models[Model Registry]
            Experiments[Experiment Tracker]
            Policy[Policy & Compliance Engine]
            Lineage[Lineage Service]
        end
    end

    subgraph Services[Decisioning & Execution Services]
        Risk[Risk Engine]
        Strat[Strategy Optimizer]
        Backtest[Backtesting Service]
        Exec[Execution Gateway]
        Sim[Simulation Sandbox]
    end

    subgraph Delivery[Delivery & Experience Channels]
        UI[Trader Web UI]
        Mobile[Mobile & Desktop Apps]
        API[Public & Partner APIs]
        Reports[Automated Reporting]
        Webhooks[Real-time Webhooks]
    end

    subgraph Oversight[Observability & Control]
        Monitor[Unified Monitoring]
        Alerting[Intelligent Alerting]
        Audit[Audit Trail Service]
        FeatureGuard[Feature Guardrails]
    end

    External --> Integration
    Integration --> DataLayer
    Integration --> ModelOps
    DataLayer --> Services
    ModelOps --> Services
    Services --> Delivery
    Delivery -->|Feedback & Orders| Services
    Services -->|Performance & Signals| DataLayer
    ModelOps -->|Lineage & Policies| DataLayer
    Oversight --> Integration
    Oversight --> Core
    Oversight --> Services
    Oversight --> Delivery
    Integration -->|Ingestion Metrics| Oversight
    Services -->|Execution Telemetry| Oversight
