{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "γ (Gamma) — PSD Slope",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, instrument, gamma FROM coherence_signals WHERE timestamp > dateadd('h', -6, now()) AND instrument = '$instrument' ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 1.2 }
            ]
          },
          "min": 0,
          "max": 2
        }
      },
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "R(t) — Kuramoto Order Parameter",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, instrument, order_parameter_R FROM coherence_signals WHERE timestamp > dateadd('h', -6, now()) AND instrument = '$instrument' ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "title": "κ — Ricci Curvature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, instrument, ricci_curvature FROM coherence_signals WHERE timestamp > dateadd('h', -6, now()) AND instrument = '$instrument' ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "title": "Regime State",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, regime FROM coherence_signals WHERE timestamp > dateadd('h', -6, now()) AND instrument = '$instrument' ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 },
          "mappings": [
            { "type": "value", "options": { "COHERENT": { "color": "green", "index": 0, "text": "COHERENT" } } },
            { "type": "value", "options": { "METASTABLE": { "color": "yellow", "index": 1, "text": "METASTABLE" } } },
            { "type": "value", "options": { "DECOHERENT": { "color": "blue", "index": 2, "text": "DECOHERENT" } } },
            { "type": "value", "options": { "CRITICAL": { "color": "red", "index": 3, "text": "CRITICAL" } } }
          ]
        }
      }
    },
    {
      "title": "Signal Strength",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT timestamp as time, signal_strength FROM coherence_signals WHERE timestamp > dateadd('h', -1, now()) AND instrument = '$instrument' ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -1,
          "max": 1,
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "title": "Risk Scalar (per instrument)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "postgres", "uid": "questdb" },
      "targets": [
        {
          "rawSql": "SELECT instrument, last(risk_scalar) as risk_scalar FROM coherence_signals WHERE timestamp > dateadd('m', -5, now()) GROUP BY instrument",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "instrument",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "questdb" },
        "query": "SELECT DISTINCT instrument FROM coherence_signals",
        "current": { "text": "EURUSD", "value": "EURUSD" },
        "refresh": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "CoherenceBridge — Regime Signals",
  "uid": "coherence-bridge-v1"
}
